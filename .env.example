# ==========================================
# VGC ANALYST - ENVIRONMENT TEMPLATE
# ==========================================
# Copy this file to '.env' and fill in your real values.
# DO NOT commit your real '.env' file to version control!

# --- Database Settings ---
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_NAME=vgc_db
# Optional: Use a full URL for complex setups (MySQL, PostgreSQL, etc.)
# DATABASE_URL=mysql+pymysql://user:pass@host/dbname

# --- Security ---
# This must match between your Backend, Frontend, and Tools
VGC_API_KEY=vgc_dev_key_2026
# Frontend specific (Vite requires VITE_ prefix)
VITE_VGC_API_KEY=vgc_dev_key_2026

# --- AI & External APIs ---
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- Services ---
# Port for the Node.js Damage Calculation Microservice
CALC_SERVICE_PORT=3001
CALC_SERVICE_URL=http://localhost:3001/calculate

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
