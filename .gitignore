# =========================
# Backend (FastAPI / Python)
# =========================

# Virtual Environments (This is the big one!)
venv/
env/
.venv/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Local database files (if you use SQLite later)
*.sqlite3

# =========================
# Frontend (React / Node)
# =========================

# Node Modules (Never upload this, it's massive)
node_modules/

# Production build folders
dist/
build/

# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# General / Security
# =========================

# Environment variables (NEVER upload your secrets/passwords)
.env
.env.local

# OS generated files
.DS_Store
Thumbs.db

# IDE / Editor folders (Keeps your repo clean for other developers)
.vscode/
.idea/